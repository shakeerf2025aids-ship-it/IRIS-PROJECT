# FastAPI Backend Configuration

# Environment: development, staging, production
ENVIRONMENT=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# CORS Configuration
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://10.0.2.2:8000
CORS_CREDENTIALS=true
CORS_METHODS=*
CORS_HEADERS=*

# Model Configuration
# Local development (relative path from backend directory)
MODEL_PATH=ml/models/best_model_epoch4.pth

# Production model paths (set one based on deployment environment)
# AWS S3
# MODEL_S3_BUCKET=iris-models
# MODEL_S3_KEY=models/best_model_epoch4.pth
# AWS_REGION=us-east-1

# HuggingFace Hub (alternative)
# MODEL_HF_REPO=your-username/iris-glaucoma-model
# MODEL_HF_MODEL_NAME=best_model_epoch4.pth

# Device Configuration
# Options: auto, cuda, cpu
DEVICE=auto

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Authentication
# For demo: any non-empty token works
# For production: implement proper JWT validation
AUTH_ENABLED=true
AUTH_PROVIDER=firebase

# Performance
INFERENCE_TIMEOUT_SECONDS=30
MAX_FILE_SIZE_MB=50

# Monitoring (optional)
SENTRY_DSN=
